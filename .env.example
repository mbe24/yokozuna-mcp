# yokozuna-mcp configuration
# Copy to .env for local development, or set these in your MCP client's `env` block.
#
# The access key pair should belong to a dedicated READ-ONLY service account whose
# role has these capabilities:
#   - Data Management -> Download Search Results
#   - Data Management -> View Collectors
#   - Alerting -> View Monitors (optional; only for sumo_list_monitors)
# plus search access to the indexes/partitions holding your preview & prod logs.

# --- Required ---
SUMO_ACCESS_ID=
# Never logged or echoed by the server.
SUMO_ACCESS_KEY=

# --- Optional ---
# Sumo deployment code: au, ca, ch, de, eu, fed, in, jp, kr, us1, us2. Default: eu
#SUMO_DEPLOYMENT=eu

# Explicit API base URL override (takes precedence over SUMO_DEPLOYMENT).
# With or without trailing slash / the /api suffix; must be https.
#SUMO_ENDPOINT=https://api.eu.sumologic.com/api/

# UI origin used ONLY to build "open in Sumo UI" deep links (not for the API — the API
# host is always api.<code>.sumologic.com). Many orgs have a company-specific UI host;
# set this so links point at your actual UI. Default: service.<code>.sumologic.com
#SUMO_UI_BASE_URL=https://<org>.<deployment>.sumologic.com

# IANA timezone used when a tool call omits timeZone. Default: UTC
#SUMO_DEFAULT_TIMEZONE=UTC

# When set, embedded into tool descriptions as the recommended query prefix.
# Queries are never mutated.
#SUMO_DEFAULT_SOURCE_CATEGORY=kubernetes/myservice/*/backend

# Directory sumo_export_results writes NDJSON files to. Default: OS temp dir
#YOKOZUNA_EXPORT_DIR=

# Default output verbosity: summary | compact | full | raw. Default: compact
#YOKOZUNA_DEFAULT_DETAIL=compact

# Default inline result limit. Default: 100
#YOKOZUNA_DEFAULT_LIMIT=100

# Safety cap (chars) for the log `message` field; only trips on pathological blobs.
# Default: 10000
#YOKOZUNA_MAX_MESSAGE_CHARS=10000

# JSON path (inside _raw) of the log level, used by detail:summary side-aggregates,
# sumo_error_digest, and the levelname facet. Default: log.levelname
#YOKOZUNA_LEVEL_EXPR=log.levelname

# sumo_new_since freshness lag (seconds): poll windows end at now - margin so
# late-arriving logs are not skipped (results are complete but this many seconds stale).
# Default: 180
#YOKOZUNA_SETTLE_MARGIN_SECONDS=180

# Default dimensions for sumo_facets (comma-separated). "_"-prefixed = native Sumo
# fields; anything else is parsed from the JSON payload as log.<dimension>.
# Default: _sourcecategory,_sourcehost,levelname,status,path
#YOKOZUNA_FACET_DIMENSIONS=_sourcecategory,_sourcehost,levelname,status,path

# Whole-response safety cap (chars) for inline tool results; oversized responses are
# tail-truncated with a pointer to sumo_export_results (headers/counts always survive).
# Default: 200000, minimum 1000
#YOKOZUNA_MAX_RESPONSE_CHARS=200000

# Minutes a kept job (sumo_create_search_job / keepJob: true) may sit idle before the
# server auto-deletes it; any access resets the timer. Default: 10
#YOKOZUNA_KEEPALIVE_IDLE_MINUTES=10

# Max jobs tracked by the keepalive at once; beyond the cap the stalest job is evicted
# (logged to stderr with the job id) and left to expire server-side. Default: 20
#YOKOZUNA_KEEPALIVE_MAX_JOBS=20
